# Banco de dados
DATABASE_URL=postgresql://usuario:senha@host:5432/filhos_de_maria

# JWT — gere com: openssl rand -base64 32
JWT_SECRET=

# Ambiente
NODE_ENV=production

# Admin inicial (usado pelo seed no primeiro boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Opcional: reset de senha de emergência
# RESET_ADMIN_PASSWORD=
# RESET_ADMIN_USERNAME=
